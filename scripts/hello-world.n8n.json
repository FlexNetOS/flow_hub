{
  "name": "hello-world",
  "nodes": [
    {
      "parameters": { "updates": [{ "event": "activated" }] },
      "name": "When workflow is activated",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "mode": "customize",
        "outputFormat": "json",
        "jsonContent": "{\"message\": \"Hello from the FlexNetOS workflow hub!\", \"timestamp\": \"={{$now.toISO()}}\"}"
      },
      "name": "Output",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.2,
      "position": [500, 300]
    }
  ],
  "connections": {
    "When workflow is activated": {
      "main": [[{"node": "Output", "type": "main", "index": 0}]]
    }
  },
  "settings": { "saveExecutionProgress": true }
}
